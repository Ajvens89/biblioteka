# Skopiuj te linie do Firebase Console:
# App Hosting → backend → Settings → Environment → wklej całość naraz
#
# Baza: Neon (https://neon.tech) — darmowy Postgres, jednorazowo skopiuj URL z dashboardu.
# Nie musisz „obsługiwać” Neon — to tylko magazyn danych w tle.

DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require

AUTH_PROVIDER=local
AUTH_SECRET=WYMIEN_NA_LOSOWY_CIAG_MIN_32_ZNAKI
ALLOW_LOCAL_AUTH_IN_PRODUCTION=true

APP_URL=https://TWOJ-BACKEND.web.app
NEXT_PUBLIC_APP_URL=https://TWOJ-BACKEND.web.app

# Opcjonalnie — okładki z Google Grafika (serwerowy klucz, nie Firebase Browser key)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=8203af11758114f71

# Opcjonalnie
GOOGLE_BOOKS_API_KEY=
BGG_TOKEN=
