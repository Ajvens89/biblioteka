generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  GUEST
  USER
  LIBRARIAN
  ADMIN
}

enum GameType {
  BOARD
  CARD
  RPG
  WARGAME
  EDUCATIONAL
  PARTY
  FAMILY
}

/** Zbiór biblioteczny: planszówki vs gry fabularne (RPG). */
enum GameCollectionType {
  BOARD_GAME
  RPG
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum CopyStatus {
  AVAILABLE
  RESERVED
  BORROWED
  DAMAGED
  LOST
  REPAIR
  RETIRED
}

enum CopyCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum ReservationStatus {
  PENDING
  APPROVED
  READY_FOR_PICKUP
  BORROWED
  RETURNED
  CANCELLED
  EXPIRED
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  LOST
  DAMAGED
}

enum EanValidationStatus {
  VALID
  MISSING
  INVALID_CHECKSUM
  NEEDS_VERIFICATION
}

enum NotificationType {
  RESERVATION_CONFIRMED
  READY_FOR_PICKUP
  RETURN_REMINDER
  OVERDUE_RETURN
  RESERVATION_EXPIRED
  WAITLIST_AVAILABLE
  EXTENSION_APPROVED
  EXTENSION_REJECTED
  EVENT_REMINDER
  GENERAL
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  FULFILLED
  EXPIRED
  CANCELLED
}

enum ExtensionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  RESERVE
  APPROVE
  BORROW
  RETURN
  CANCEL
  IMPORT
  EXPORT
  SETTINGS
}

model Profile {
  id                String    @id @default(uuid())
  authUserId        String    @unique @map("auth_user_id")
  email             String    @unique
  fullName          String?   @map("full_name")
  phone             String?
  role              UserRole  @default(USER)
  isBlocked         Boolean   @default(false) @map("is_blocked")
  adminNotes        String?   @map("admin_notes")
  avatarUrl         String?   @map("avatar_url")
  passwordHash      String?   @map("password_hash")
  emailNotificationsEnabled Boolean @default(true) @map("email_notifications_enabled")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  reservations      Reservation[]
  loans             Loan[]
  notifications     Notification[]
  auditLogs         AuditLog[]    @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  waitlistEntries   WaitlistEntry[]
  extensionRequests LoanExtensionRequest[] @relation("ExtensionRequester")
  reviewedExtensions LoanExtensionRequest[] @relation("ExtensionReviewer")
  wishlistItems     WishlistItem[]
  gameRatings       GameRating[]

  @@index([email])
  @@index([role])
  @@map("profiles")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  games       GameCategory[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  games     GameTag[]

  @@map("tags")
}

model Publisher {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  website   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  games     Game[]

  @@map("publishers")
}

model Designer {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  games     Game[]

  @@map("designers")
}

model Game {
  id               String              @id @default(uuid())
  title            String
  slug             String              @unique
  ean              String?
  eanValidationStatus EanValidationStatus? @map("ean_validation_status")
  collectionType   GameCollectionType  @default(BOARD_GAME) @map("collection_type")
  description      String?             @db.Text
  shortDescription String?             @map("short_description")
  minPlayers       Int                 @default(1) @map("min_players")
  maxPlayers       Int                 @default(4) @map("max_players")
  minAge           Int                 @default(8) @map("min_age")
  minPlayTime      Int                 @default(30) @map("min_play_time")
  maxPlayTime      Int                 @default(60) @map("max_play_time")
  difficulty       Difficulty          @default(MEDIUM)
  type             GameType            @default(BOARD)
  publisherId      String?    @map("publisher_id")
  designerId       String?    @map("designer_id")
  yearPublished    Int?       @map("year_published")
  coverImageUrl         String?    @map("cover_image_url")
  coverImageSource      String?    @map("cover_image_source")
  coverImageExternalId  String?    @map("cover_image_external_id")
  instructionUrl        String?    @map("instruction_url")
  isActive         Boolean    @default(true) @map("is_active")
  isFeatured       Boolean    @default(false) @map("is_featured")
  popularityCount  Int        @default(0) @map("popularity_count")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  publisher        Publisher? @relation(fields: [publisherId], references: [id])
  designer         Designer?  @relation(fields: [designerId], references: [id])
  copies           GameCopy[]
  images           GameImage[]
  categories       GameCategory[]
  tags             GameTag[]
  reservations     Reservation[]
  slugAliases      GameSlugAlias[]
  waitlistEntries  WaitlistEntry[]
  wishlistItems    WishlistItem[]
  gameRatings      GameRating[]

  @@index([title])
  @@index([isActive])
  @@index([isFeatured])
  @@index([popularityCount])
  @@index([type])
  @@index([ean])
  @@index([collectionType])
  @@map("games")
}

model GameSlugAlias {
  id        String   @id @default(uuid())
  gameId    String   @map("game_id")
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("game_slug_aliases")
}

model GameCategory {
  gameId     String @map("game_id")
  categoryId String @map("category_id")

  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([gameId, categoryId])
  @@map("game_categories")
}

model GameTag {
  gameId String @map("game_id")
  tagId  String @map("tag_id")

  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gameId, tagId])
  @@map("game_tags")
}

model GameImage {
  id        String   @id @default(uuid())
  gameId    String   @map("game_id")
  url       String
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("game_images")
}

model GameCopy {
  id              String        @id @default(uuid())
  gameId          String        @map("game_id")
  inventoryNumber String        @unique @map("inventory_number")
  barcode         String?       @unique
  status          CopyStatus    @default(AVAILABLE)
  condition       CopyCondition @default(GOOD)
  location        String?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  game            Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  reservations    Reservation[]
  loans           Loan[]

  @@index([gameId])
  @@index([status])
  @@map("game_copies")
}

model Reservation {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  gameId          String            @map("game_id")
  copyId          String?           @map("copy_id")
  status          ReservationStatus @default(PENDING)
  pickupDeadline  DateTime?         @map("pickup_deadline")
  notes           String?
  cancelledAt     DateTime?         @map("cancelled_at")
  approvedAt      DateTime?         @map("approved_at")
  readyAt         DateTime?         @map("ready_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user            Profile           @relation(fields: [userId], references: [id])
  game            Game              @relation(fields: [gameId], references: [id])
  copy            GameCopy?         @relation(fields: [copyId], references: [id])
  loan            Loan?

  @@index([userId])
  @@index([gameId])
  @@index([status])
  @@index([createdAt])
  @@map("reservations")
}

model Loan {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  copyId          String     @map("copy_id")
  reservationId   String?    @unique @map("reservation_id")
  status          LoanStatus @default(ACTIVE)
  borrowedAt      DateTime   @default(now()) @map("borrowed_at")
  dueAt           DateTime   @map("due_at")
  returnedAt      DateTime?  @map("returned_at")
  returnNotes     String?    @map("return_notes") @db.Text
  damageNotes     String?    @map("damage_notes") @db.Text
  extensionCount  Int        @default(0) @map("extension_count")
  lastReminderAt  DateTime?  @map("last_reminder_at")
  overdueNotifiedAt DateTime? @map("overdue_notified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user            Profile    @relation(fields: [userId], references: [id])
  copy            GameCopy   @relation(fields: [copyId], references: [id])
  reservation     Reservation? @relation(fields: [reservationId], references: [id])
  extensions      LoanExtension[]
  extensionRequests LoanExtensionRequest[]

  @@index([userId])
  @@index([copyId])
  @@index([status])
  @@index([dueAt])
  @@map("loans")
}

model LoanExtension {
  id          String   @id @default(uuid())
  loanId      String   @map("loan_id")
  previousDue DateTime @map("previous_due")
  newDue      DateTime @map("new_due")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_extensions")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?     @map("actor_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  metadata   Json?
  ipAddress  String?     @map("ip_address")
  createdAt  DateTime    @default(now()) @map("created_at")

  actor      Profile?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String           @db.Text
  linkUrl   String?          @map("link_url")
  isRead    Boolean          @default(false) @map("is_read")
  sentEmail Boolean          @default(false) @map("sent_email")
  createdAt DateTime         @default(now()) @map("created_at")

  user      Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model RateLimitEntry {
  id          String   @id @default(uuid())
  scope       String
  keyHash     String   @map("key_hash")
  count       Int      @default(1)
  windowStart DateTime @map("window_start")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([scope, keyHash, windowStart])
  @@index([expiresAt])
  @@map("rate_limit_entries")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model CronJobLog {
  id         String    @id @default(uuid())
  jobName    String    @map("job_name")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  status     String
  processed  Int       @default(0)
  metadata   Json?
  error      String?   @db.Text

  @@index([jobName, startedAt])
  @@map("cron_job_logs")
}

model WaitlistEntry {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  gameId     String         @map("game_id")
  position   Int
  status     WaitlistStatus @default(WAITING)
  notifiedAt DateTime?      @map("notified_at")
  expiresAt  DateTime?      @map("expires_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, status, position])
  @@index([userId, gameId])
  @@index([userId, status])
  @@map("waitlist_entries")
}

model LoanExtensionRequest {
  id            String                 @id @default(uuid())
  loanId        String                 @map("loan_id")
  userId        String                 @map("user_id")
  status        ExtensionRequestStatus @default(PENDING)
  requestedDays Int                    @default(7) @map("requested_days")
  reason        String?
  reviewedAt    DateTime?              @map("reviewed_at")
  reviewedById  String?                @map("reviewed_by_id")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  loan       Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user       Profile  @relation("ExtensionRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy Profile? @relation("ExtensionReviewer", fields: [reviewedById], references: [id])

  @@index([loanId])
  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
  @@map("loan_extension_requests")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@map("wishlist_items")
}

model GameRating {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId])
  @@index([gameId, rating])
  @@map("game_ratings")
}
