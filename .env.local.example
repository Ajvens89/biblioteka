# === LOCAL — skopiuj do .env ===
# Staging/production: ustaw zmienne w Vercel (Preview / Production), nie w tym pliku.

# Docker:
# DATABASE_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"
# DIRECT_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"
#
# Prisma Dev (npm run dev:db) — port TCP z `npx prisma dev ls` (np. 51214), BEZ pgbouncer:
# DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
# DIRECT_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

DATABASE_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"
DIRECT_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"

AUTH_PROVIDER=local
AUTH_SECRET="zmien-na-losowy-ciag-minimum-32-znaki-dev"

APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

RESEND_API_KEY=""
EMAIL_FROM=""
GOOGLE_BOOKS_API_KEY=""

# Google Grafika (Custom Search API) — ~100 zapytań/dzień za darmo
# https://programmablesearchengine.google.com/ + włącz Custom Search API w Google Cloud
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_CX=""

# Okładki — UPCitemdb działa bez klucza (~100 zapytań/dzień, automatycznie)
# UPCITEMDB_USER_KEY=""
# UPCITEMDB_KEY_TYPE="3"
# BGG_TOKEN=""  # opcjonalnie, boardgamegeek.com/applications
# IMPORT_FETCH_COVERS=false

ALLOW_LOCAL_AUTH_IN_PRODUCTION=false
