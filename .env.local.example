# === Tryb lokalny (bez Supabase) — skopiuj do .env ===

# PostgreSQL (Docker: docker compose up -d)
DATABASE_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"

# Logowanie lokalne (hasła w tabeli profiles.password_hash)
AUTH_PROVIDER=local
AUTH_SECRET="zmien-na-losowy-ciag-min-32-znaki-dev"

# Supabase — zostaw puste lub placeholdery (aplikacja użyje trybu local)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# E-mail — opcjonalnie (bez klucza: log w konsoli)
RESEND_API_KEY=""
EMAIL_FROM=""
