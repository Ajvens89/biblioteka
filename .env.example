# =============================================================================
# Biblioteka Zakątka Fantastyki — szablon zmiennych (BEZ prawdziwych sekretów)
# Skopiuj do .env (local) lub ustaw w Vercel → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# 1) LOCAL (dev na swoim komputerze)
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"
# DIRECT_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"
# AUTH_PROVIDER=local
# AUTH_SECRET="losowy-ciag-minimum-32-znaki-tylko-dev"
# APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# -----------------------------------------------------------------------------
# 2) STAGING / PREVIEW (Vercel Preview + osobny projekt Supabase)
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[pass]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
# AUTH_PROVIDER=supabase
# AUTH_SECRET="losowy-ciag-minimum-32-znaki-staging"
# APP_URL="https://biblioteka-xxx.vercel.app"
# NEXT_PUBLIC_APP_URL="https://biblioteka-xxx.vercel.app"
# NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# ALLOW_LOCAL_AUTH_IN_PRODUCTION=false

# -----------------------------------------------------------------------------
# 3) PRODUCTION (osobny projekt Supabase + domena prod — NIE używaj na staging)
# -----------------------------------------------------------------------------
# DATABASE_URL=
# DIRECT_URL=
# AUTH_PROVIDER=supabase
# AUTH_SECRET=
# APP_URL=
# NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# ALLOW_LOCAL_AUTH_IN_PRODUCTION=false

# =============================================================================
# Wspólne (wszystkie środowiska)
# =============================================================================

DATABASE_URL=
DIRECT_URL=

AUTH_SECRET=
AUTH_PROVIDER=local

APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=
EMAIL_FROM=Biblioteka Zakątka <kontakt@twoja-domena.pl>

GOOGLE_BOOKS_API_KEY=

ALLOW_LOCAL_AUTH_IN_PRODUCTION=false
