# === Baza (wymagana — prawdziwy PostgreSQL) ===
# Lokalnie: docker compose up -d → DATABASE_URL poniżej
# Supabase: Connection string z panelu projektu
DATABASE_URL="postgresql://biblioteka:biblioteka@localhost:5432/biblioteka"

# === Auth: local | supabase (auto: local gdy brak prawdziwych kluczy Supabase) ===
AUTH_PROVIDER=local
AUTH_SECRET="zmien-na-losowy-ciag-minimum-32-znaki"
# Produkcja + local tylko świadomie:
# ALLOW_LOCAL_AUTH_IN_PRODUCTION=true

# === Supabase (opcjonalne w dev — zobacz docs/SUPABASE.md) ===
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# === Aplikacja ===
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === E-mail (opcjonalnie — bez klucza: adapter loguje w konsoli) ===
RESEND_API_KEY=""
EMAIL_FROM="Biblioteka Zakątka <kontakt@twoja-domena.pl>"
